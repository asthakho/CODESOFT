<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Titanic Survival Prediction</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ocean: #0a1628;
    --deep: #0d1f3c;
    --navy: #122a4e;
    --steel: #1e3a5f;
    --ice: #a8c5da;
    --frost: #d4e8f5;
    --gold: #c9a84c;
    --amber: #e8c56a;
    --coral: #e05a6a;
    --mint: #4ecdc4;
    --text: #e8f0f7;
    --muted: #7a9bb5;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--ocean);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated ocean background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse 80% 50% at 20% 80%, rgba(14,40,80,0.6) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 20%, rgba(10,25,60,0.4) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

  /* HEADER */
  header {
    padding: 60px 0 40px;
    text-align: center;
    position: relative;
  }
  .ship-emoji { font-size: 48px; display: block; margin-bottom: 16px; animation: float 4s ease-in-out infinite; }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

  header h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    background: linear-gradient(135deg, var(--frost) 0%, var(--gold) 60%, var(--amber) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
  }
  header p {
    color: var(--muted);
    margin-top: 12px;
    font-size: 0.85rem;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--steel), var(--gold), var(--steel), transparent);
    margin: 8px 0 48px;
  }

  /* STAT CARDS */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }
  .stat-card {
    background: linear-gradient(135deg, var(--deep), var(--navy));
    border: 1px solid var(--steel);
    border-radius: 12px;
    padding: 24px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s, border-color 0.3s;
  }
  .stat-card:hover { transform: translateY(-4px); border-color: var(--gold); }
  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), var(--mint));
  }
  .stat-card .value {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--amber);
    line-height: 1;
  }
  .stat-card .label {
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .stat-card .sub {
    font-size: 0.75rem;
    color: var(--ice);
    margin-top: 4px;
  }

  /* SECTIONS */
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: var(--frost);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--steel), transparent);
  }

  /* MODEL COMPARISON */
  .models-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }
  .model-card {
    background: var(--deep);
    border: 1px solid var(--steel);
    border-radius: 12px;
    padding: 24px;
    position: relative;
    transition: all 0.3s;
  }
  .model-card.best {
    border-color: var(--gold);
    background: linear-gradient(135deg, var(--deep), rgba(201,168,76,0.08));
  }
  .model-card.best::after {
    content: '★ BEST';
    position: absolute;
    top: 12px; right: 12px;
    font-size: 0.65rem;
    color: var(--gold);
    letter-spacing: 2px;
    border: 1px solid var(--gold);
    padding: 2px 8px;
    border-radius: 20px;
  }
  .model-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--frost);
    margin-bottom: 16px;
  }
  .acc-display {
    font-size: 2.8rem;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    color: var(--mint);
    line-height: 1;
  }
  .acc-label { font-size: 0.7rem; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-top: 4px; }
  .progress-bar {
    height: 4px;
    background: var(--steel);
    border-radius: 2px;
    margin-top: 16px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--mint), var(--gold));
    transition: width 1.5s cubic-bezier(0.4,0,0.2,1);
    width: 0;
  }
  .cv-info { font-size: 0.75rem; color: var(--muted); margin-top: 10px; }

  /* CHARTS GRID */
  .charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 40px;
  }
  @media (max-width: 700px) { .charts-grid { grid-template-columns: 1fr; } }

  .chart-card {
    background: var(--deep);
    border: 1px solid var(--steel);
    border-radius: 12px;
    padding: 24px;
  }
  .chart-title {
    font-size: 0.8rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 20px;
  }

  /* BAR CHARTS */
  .bar-group { margin-bottom: 14px; }
  .bar-label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .bar-label { font-size: 0.8rem; color: var(--ice); }
  .bar-value { font-size: 0.8rem; color: var(--amber); font-weight: 500; }
  .bar-track { height: 8px; background: var(--steel); border-radius: 4px; overflow: hidden; }
  .bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 1.5s cubic-bezier(0.4,0,0.2,1);
    width: 0;
  }
  .bar-fill.female { background: linear-gradient(90deg, var(--coral), #f08090); }
  .bar-fill.male { background: linear-gradient(90deg, #4a90d9, var(--mint)); }
  .bar-fill.c1 { background: linear-gradient(90deg, var(--gold), var(--amber)); }
  .bar-fill.c2 { background: linear-gradient(90deg, var(--mint), #7eddd8); }
  .bar-fill.c3 { background: linear-gradient(90deg, var(--muted), var(--ice)); }
  .bar-fill.feat { background: linear-gradient(90deg, var(--mint), var(--gold)); }
  .bar-fill.emb { background: linear-gradient(90deg, #a78bfa, #818cf8); }

  /* CONFUSION MATRIX */
  .cm-grid {
    display: grid;
    grid-template-columns: auto 1fr 1fr;
    gap: 4px;
    max-width: 300px;
    margin: 0 auto;
  }
  .cm-header { font-size: 0.7rem; color: var(--muted); text-align: center; padding: 8px; letter-spacing: 1px; }
  .cm-row-label { font-size: 0.7rem; color: var(--muted); display: flex; align-items: center; padding-right: 8px; white-space: nowrap; }
  .cm-cell {
    border-radius: 8px;
    padding: 20px 10px;
    text-align: center;
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    transition: all 0.3s;
  }
  .cm-cell:hover { transform: scale(1.05); }
  .cm-tp { background: rgba(78,205,196,0.25); color: var(--mint); border: 1px solid rgba(78,205,196,0.4); }
  .cm-tn { background: rgba(78,205,196,0.15); color: var(--mint); border: 1px solid rgba(78,205,196,0.3); }
  .cm-fp { background: rgba(224,90,106,0.2); color: var(--coral); border: 1px solid rgba(224,90,106,0.3); }
  .cm-fn { background: rgba(224,90,106,0.15); color: var(--coral); border: 1px solid rgba(224,90,106,0.25); }
  .cm-sub { font-size: 0.65rem; color: var(--muted); margin-top: 4px; }
  .cm-legend { display: flex; gap: 16px; justify-content: center; margin-top: 16px; flex-wrap: wrap; }
  .cm-legend-item { font-size: 0.7rem; color: var(--muted); display: flex; align-items: center; gap: 6px; }
  .cm-dot { width: 8px; height: 8px; border-radius: 2px; }

  /* PREDICTOR */
  .predictor-card {
    background: linear-gradient(135deg, var(--deep), var(--navy));
    border: 1px solid var(--steel);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 48px;
    position: relative;
    overflow: hidden;
  }
  .predictor-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--coral), var(--gold), var(--mint));
  }
  .predictor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }
  .field-group label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .field-group select, .field-group input {
    width: 100%;
    background: var(--ocean);
    border: 1px solid var(--steel);
    color: var(--text);
    padding: 10px 14px;
    border-radius: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 0.85rem;
    transition: border-color 0.3s;
    appearance: none;
  }
  .field-group select:focus, .field-group input:focus {
    outline: none;
    border-color: var(--gold);
  }

  .predict-btn {
    background: linear-gradient(135deg, var(--gold), var(--amber));
    color: var(--ocean);
    border: none;
    padding: 14px 40px;
    font-family: 'DM Mono', monospace;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s;
    display: block;
    margin: 0 auto;
  }
  .predict-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 30px rgba(201,168,76,0.4);
  }

  .prediction-result {
    margin-top: 24px;
    padding: 24px;
    border-radius: 12px;
    text-align: center;
    display: none;
    animation: fadeIn 0.5s ease;
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .prediction-result.survived {
    background: rgba(78,205,196,0.12);
    border: 1px solid rgba(78,205,196,0.4);
  }
  .prediction-result.died {
    background: rgba(224,90,106,0.12);
    border: 1px solid rgba(224,90,106,0.4);
  }
  .result-icon { font-size: 3rem; display: block; margin-bottom: 12px; }
  .result-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    margin-bottom: 8px;
  }
  .result-prob { font-size: 0.8rem; color: var(--muted); letter-spacing: 2px; }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 32px 0;
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 2px;
    border-top: 1px solid var(--steel);
  }
</style>
</head>
<body>
<div class="container">

  <header>
    <span class="ship-emoji">🚢</span>
    <h1>Titanic Survival Prediction</h1>
    <p>Machine Learning Analysis · April 1912</p>
  </header>
  <div class="divider"></div>

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="value">891</div>
      <div class="label">Passengers</div>
      <div class="sub">Training Dataset</div>
    </div>
    <div class="stat-card">
      <div class="value">38.4%</div>
      <div class="label">Survival Rate</div>
      <div class="sub">342 survived</div>
    </div>
    <div class="stat-card">
      <div class="value">83.2%</div>
      <div class="label">Best Accuracy</div>
      <div class="sub">Random Forest</div>
    </div>
    <div class="stat-card">
      <div class="value">12</div>
      <div class="label">Features</div>
      <div class="sub">Engineered</div>
    </div>
    <div class="stat-card">
      <div class="value">3</div>
      <div class="label">Models Tested</div>
      <div class="sub">5-fold CV</div>
    </div>
  </div>

  <!-- MODELS -->
  <div class="section-title">Model Performance</div>
  <div class="models-grid">
    <div class="model-card best">
      <div class="model-name">Random Forest</div>
      <div class="acc-display">83.2%</div>
      <div class="acc-label">Test Accuracy</div>
      <div class="progress-bar"><div class="progress-fill" data-width="83.2"></div></div>
      <div class="cv-info">CV Mean: 78.2% ± 2.1%</div>
    </div>
    <div class="model-card">
      <div class="model-name">Gradient Boosting</div>
      <div class="acc-display">81.0%</div>
      <div class="acc-label">Test Accuracy</div>
      <div class="progress-bar"><div class="progress-fill" data-width="81.0"></div></div>
      <div class="cv-info">CV Mean: 80.6% ± 2.8%</div>
    </div>
    <div class="model-card">
      <div class="model-name">Logistic Regression</div>
      <div class="acc-display">79.9%</div>
      <div class="acc-label">Test Accuracy</div>
      <div class="progress-bar"><div class="progress-fill" data-width="79.9"></div></div>
      <div class="cv-info">CV Mean: 79.4% ± 2.9%</div>
    </div>
  </div>

  <!-- CHARTS -->
  <div class="charts-grid">
    <!-- Survival by Gender -->
    <div class="chart-card">
      <div class="chart-title">Survival by Gender</div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">Female</span><span class="bar-value">74.2%</span></div>
        <div class="bar-track"><div class="bar-fill female" data-width="74.2"></div></div>
      </div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">Male</span><span class="bar-value">18.9%</span></div>
        <div class="bar-track"><div class="bar-fill male" data-width="18.9"></div></div>
      </div>
      <div style="margin-top:20px; font-size:0.75rem; color:var(--muted); line-height:1.6;">
        Gender was the strongest social predictor — "women and children first" protocol was largely followed.
      </div>
    </div>

    <!-- Survival by Class -->
    <div class="chart-card">
      <div class="chart-title">Survival by Passenger Class</div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">1st Class</span><span class="bar-value">63.0%</span></div>
        <div class="bar-track"><div class="bar-fill c1" data-width="63.0"></div></div>
      </div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">2nd Class</span><span class="bar-value">47.3%</span></div>
        <div class="bar-track"><div class="bar-fill c2" data-width="47.3"></div></div>
      </div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">3rd Class</span><span class="bar-value">24.2%</span></div>
        <div class="bar-track"><div class="bar-fill c3" data-width="24.2"></div></div>
      </div>
    </div>

    <!-- Feature Importance -->
    <div class="chart-card">
      <div class="chart-title">Feature Importance (Random Forest)</div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">Fare</span><span class="bar-value">22.2%</span></div>
        <div class="bar-track"><div class="bar-fill feat" data-width="22.2"></div></div>
      </div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">Sex</span><span class="bar-value">20.3%</span></div>
        <div class="bar-track"><div class="bar-fill feat" data-width="20.3"></div></div>
      </div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">Age</span><span class="bar-value">18.9%</span></div>
        <div class="bar-track"><div class="bar-fill feat" data-width="18.9"></div></div>
      </div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">Title</span><span class="bar-value">10.7%</span></div>
        <div class="bar-track"><div class="bar-fill feat" data-width="10.7"></div></div>
      </div>
      <div class="bar-group">
        <div class="bar-label-row"><span class="bar-label">Pclass</span><span class="bar-value">7.0%</span></div>
        <div class="bar-track"><div class="bar-fill feat" data-width="7.0"></div></div>
      </div>
    </div>

    <!-- Confusion Matrix -->
    <div class="chart-card">
      <div class="chart-title">Confusion Matrix (Random Forest)</div>
      <div class="cm-grid">
        <div></div>
        <div class="cm-header">Predicted<br>Survived</div>
        <div class="cm-header">Predicted<br>Died</div>
        <div class="cm-row-label">Actual<br>Survived</div>
        <div class="cm-cell cm-tp">92<div class="cm-sub">True Pos</div></div>
        <div class="cm-cell cm-fp">13<div class="cm-sub">False Neg</div></div>
        <div class="cm-row-label">Actual<br>Died</div>
        <div class="cm-cell cm-fn">21<div class="cm-sub">False Pos</div></div>
        <div class="cm-cell cm-tn">53<div class="cm-sub">True Neg</div></div>
      </div>
      <div class="cm-legend">
        <div class="cm-legend-item"><div class="cm-dot" style="background:var(--mint)"></div>Correct (83.2%)</div>
        <div class="cm-legend-item"><div class="cm-dot" style="background:var(--coral)"></div>Errors (16.8%)</div>
      </div>
    </div>
  </div>

  <!-- SURVIVAL by EMBARKED -->
  <div class="section-title">Survival by Embarkation Port</div>
  <div class="chart-card" style="margin-bottom:40px">
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;text-align:center;padding:16px 0">
      <div>
        <div style="font-size:2rem;font-family:'Playfair Display',serif;color:var(--amber)">55.4%</div>
        <div style="font-size:0.75rem;color:var(--muted);margin-top:4px;letter-spacing:2px">CHERBOURG (C)</div>
        <div style="font-size:0.75rem;color:var(--ice);margin-top:4px">France • Highest rate</div>
        <div class="bar-track" style="margin-top:12px"><div class="bar-fill emb" data-width="55.4"></div></div>
      </div>
      <div>
        <div style="font-size:2rem;font-family:'Playfair Display',serif;color:var(--mint)">39.0%</div>
        <div style="font-size:0.75rem;color:var(--muted);margin-top:4px;letter-spacing:2px">QUEENSTOWN (Q)</div>
        <div style="font-size:0.75rem;color:var(--ice);margin-top:4px">Ireland</div>
        <div class="bar-track" style="margin-top:12px"><div class="bar-fill emb" data-width="39.0"></div></div>
      </div>
      <div>
        <div style="font-size:2rem;font-family:'Playfair Display',serif;color:var(--muted)">33.7%</div>
        <div style="font-size:0.75rem;color:var(--muted);margin-top:4px;letter-spacing:2px">SOUTHAMPTON (S)</div>
        <div style="font-size:0.75rem;color:var(--ice);margin-top:4px">England • Lowest rate</div>
        <div class="bar-track" style="margin-top:12px"><div class="bar-fill emb" data-width="33.7"></div></div>
      </div>
    </div>
  </div>

  <!-- PREDICTOR -->
  <div class="section-title">Interactive Survival Predictor</div>
  <div class="predictor-card">
    <p style="font-size:0.78rem;color:var(--muted);margin-bottom:24px;text-align:center;letter-spacing:1px">
      Enter passenger details to estimate survival probability (rule-based approximation)
    </p>
    <div class="predictor-grid">
      <div class="field-group">
        <label>Sex</label>
        <select id="p-sex">
          <option value="female">Female</option>
          <option value="male">Male</option>
        </select>
      </div>
      <div class="field-group">
        <label>Passenger Class</label>
        <select id="p-class">
          <option value="1">1st Class</option>
          <option value="2">2nd Class</option>
          <option value="3" selected>3rd Class</option>
        </select>
      </div>
      <div class="field-group">
        <label>Age</label>
        <input type="number" id="p-age" value="30" min="0" max="100">
      </div>
      <div class="field-group">
        <label>Fare (£)</label>
        <input type="number" id="p-fare" value="15" min="0">
      </div>
      <div class="field-group">
        <label>Embarkation</label>
        <select id="p-embarked">
          <option value="S">Southampton (S)</option>
          <option value="C">Cherbourg (C)</option>
          <option value="Q">Queenstown (Q)</option>
        </select>
      </div>
      <div class="field-group">
        <label>Family Size</label>
        <input type="number" id="p-family" value="1" min="1" max="10">
      </div>
    </div>
    <button class="predict-btn" onclick="predict()">⚓ Predict Survival</button>
    <div id="result" class="prediction-result"></div>
  </div>

  <!-- METHODOLOGY -->
  <div class="section-title">Methodology</div>
  <div class="chart-card" style="margin-bottom:48px;line-height:2;font-size:0.82rem;color:var(--ice)">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
      <div>
        <div style="color:var(--gold);font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px">Data Preprocessing</div>
        · Imputed 177 missing Age values with median<br>
        · Filled 2 missing Embarked with mode<br>
        · Dropped Cabin (687 missing, ~77%)<br>
        · Label-encoded categorical variables
      </div>
      <div>
        <div style="color:var(--gold);font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px">Feature Engineering</div>
        · Extracted Title from passenger name<br>
        · Created FamilySize = SibSp + Parch + 1<br>
        · Derived IsAlone flag<br>
        · Binned Age & Fare into bands
      </div>
      <div>
        <div style="color:var(--gold);font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px">Model Training</div>
        · 80/20 train-test split (random_state=42)<br>
        · 5-fold cross validation on train set<br>
        · Tested 3 classifier algorithms<br>
        · No hyperparameter tuning (baseline)
      </div>
      <div>
        <div style="color:var(--gold);font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:12px">Key Insights</div>
        · Sex & Fare are top predictors<br>
        · 1st class women: ~97% survival<br>
        · 3rd class men: ~13% survival<br>
        · Children showed higher survival rates
      </div>
    </div>
  </div>

  <footer>
    TITANIC SURVIVAL ANALYSIS · BUILT WITH RANDOM FOREST, GRADIENT BOOSTING & LOGISTIC REGRESSION · SCIKIT-LEARN
  </footer>
</div>

<script>
  // Animate bars on load
  window.addEventListener('load', () => {
    setTimeout(() => {
      document.querySelectorAll('.bar-fill, .progress-fill').forEach(el => {
        el.style.width = el.dataset.width + '%';
      });
    }, 300);
  });

  // Rule-based predictor (approximating Random Forest logic)
  function predict() {
    const sex = document.getElementById('p-sex').value;
    const pclass = parseInt(document.getElementById('p-class').value);
    const age = parseFloat(document.getElementById('p-age').value) || 30;
    const fare = parseFloat(document.getElementById('p-fare').value) || 15;
    const embarked = document.getElementById('p-embarked').value;
    const family = parseInt(document.getElementById('p-family').value) || 1;

    // Weighted scoring
    let score = 0;
    if (sex === 'female') score += 35;
    else score -= 15;

    if (pclass === 1) score += 20;
    else if (pclass === 2) score += 8;
    else score -= 10;

    if (age < 10) score += 20;
    else if (age < 20) score += 8;
    else if (age > 60) score -= 10;

    if (fare > 100) score += 15;
    else if (fare > 50) score += 8;
    else if (fare < 10) score -= 5;

    if (embarked === 'C') score += 8;
    else if (embarked === 'Q') score += 2;

    if (family === 1) score += 5;
    else if (family <= 4) score += 10;
    else score -= 8;

    // Normalize to probability
    const prob = Math.min(95, Math.max(5, 50 + score));
    const survived = prob >= 50;

    const resultEl = document.getElementById('result');
    resultEl.style.display = 'block';
    resultEl.className = 'prediction-result ' + (survived ? 'survived' : 'died');
    resultEl.innerHTML = `
      <span class="result-icon">${survived ? '🛟' : '💀'}</span>
      <div class="result-title" style="color:${survived ? 'var(--mint)' : 'var(--coral)'}">
        ${survived ? 'LIKELY SURVIVED' : 'LIKELY DID NOT SURVIVE'}
      </div>
      <div class="result-prob">Estimated Survival Probability: ${prob}%</div>
      <div style="margin-top:12px;font-size:0.75rem;color:var(--muted)">
        ${sex === 'female' ? 'Being female significantly increased survival odds.' : 'Being male significantly reduced survival odds.'}
        ${pclass === 1 ? ' First class access to upper decks helped.' : pclass === 3 ? ' Third class passengers had limited lifeboat access.' : ''}
      </div>
    `;
  }
</script>
</body>
</html>
